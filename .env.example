# ──────────────────────────────────────────────────────────────────────────────
# VerticalVoice AI — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon (public) key — safe for client-side use, enforces RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — server-side only, bypasses RLS. NEVER expose to browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Voice Runtime ───────────────────────────────────────────────────────────
# Ultravox — primary voice AI provider
ULTRAVOX_API_KEY=
ULTRAVOX_BASE_URL=https://api.ultravox.ai/api

# Retell — fallback voice AI provider
RETELL_API_KEY=

# ─── Telephony ───────────────────────────────────────────────────────────────
# Twilio — primary telephony provider for inbound/outbound calls
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Telnyx — cost-optimized telephony for high-volume routes
TELNYX_API_KEY=
TELNYX_PHONE_NUMBER=+1XXXXXXXXXX

# ─── Authentication ─────────────────────────────────────────────────────────
# Google OAuth for calendar and workspace integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── CRM Integration ────────────────────────────────────────────────────────
# HubSpot — lead capture and CRM sync for real estate vertical
HUBSPOT_ACCESS_TOKEN=

# ─── Email ───────────────────────────────────────────────────────────────────
# Resend — transactional email (confirmations, notifications)
RESEND_API_KEY=

# ─── Security ────────────────────────────────────────────────────────────────
# Secret used to sign call-access tokens (JWT). Generate with: openssl rand -hex 32
CALL_TOKEN_SECRET=

# ─── Provider Selection ─────────────────────────────────────────────────────
# Voice provider: "ultravox" | "retell" | "mock" (for local dev without keys)
VOICE_PROVIDER=mock

# Telephony provider: "twilio" | "telnyx" | "mock" (for local dev without keys)
TELEPHONY_PROVIDER=mock

# ─── Observability (optional) ───────────────────────────────────────────────
# Sentry DSN for error tracking. Leave blank to disable.
SENTRY_DSN=

# ─── Application ────────────────────────────────────────────────────────────
# Public URL of the app (used for OAuth callbacks, webhook URLs, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# ─── Feature Flags (optional) ───────────────────────────────────────────────
# Set to "true" to enable. Defaults are all false.
# NEXT_PUBLIC_FF_HEALTHCARE_DEMO_MODE=false
# NEXT_PUBLIC_FF_RESTAURANT_ORDERING=false
# NEXT_PUBLIC_FF_REAL_ESTATE_OUTBOUND=false
# NEXT_PUBLIC_FF_OUTBOUND_CALLING=false
